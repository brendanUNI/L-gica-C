#include <stdio.h>

int main() {
    int mat[3][4];
    int vet[3] = {0, 0, 0}; 
    int somaTotal = 0;
    int i, j;

    for(i = 0; i < 3; i++) {
        for(j = 0; j < 4; j++) {
            printf("Digite o valor para mat[%i][%i]: ", i, j);
            scanf("%i", &mat[i][j]);
        }
    }

    for(i = 0; i < 3; i++) {
        for(j = 0; j < 4; j++) {
            vet[i] = vet[i] + mat[i][j];
        }
    }

    for(i = 0; i < 3; i++) {
        somaTotal = somaTotal + vet[i];
    }

    printf("\nVetor com a soma das linhas:\n");
    for(i = 0; i < 3; i++) {
        printf("Linha %i: %i\n", i, vet[i]);
    }

    printf("\nValor total da soma do vetor: %i\n", somaTotal);

    return 0;
}